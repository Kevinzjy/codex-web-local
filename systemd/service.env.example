# codex-web-local — installed to ~/.config/codex-web-local/service.env by `make systemd` (first run only).
# Uncomment lines you need, save, then: systemctl --user restart codex-web-local.service
# If you set a password, run: chmod 600 ~/.config/codex-web-local/service.env
#
# Web UI login (same as CLI --password; avoids random password you cannot see under systemd):
# CODEX_WEB_LOCAL_PASSWORD=your-secret
#
# Proxies for codex app-server (inherited by child processes):
# HTTP_PROXY=http://127.0.0.1:1087
# HTTPS_PROXY=http://127.0.0.1:1087
# ALL_PROXY=socks5://127.0.0.1:1080
